# Files and directories generated at runtime — should NOT be committed to Git

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Environment variables — NEVER commit this (contains secret API keys!)
.env

# Uploaded documents
uploaded_docs/

# Sentence transformers cache (re-downloads automatically)
.cache/

# Persisted FAISS vector index (generated at runtime)
faiss_store/

# Virtual environment
.venv/

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db
